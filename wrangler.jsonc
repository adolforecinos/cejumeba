{
  "name": "cejumeba",
  "compatibility_date": "2026-05-07",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm ci && npm run build",
    "cwd": "frontend",
    "watch_dir": "frontend/src"
  },
  "assets": {
    "directory": "frontend/dist",
    "not_found_handling": "single-page-application"
  }
}
